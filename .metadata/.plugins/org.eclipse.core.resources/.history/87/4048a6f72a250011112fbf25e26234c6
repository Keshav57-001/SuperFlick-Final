        // Use Apache PDFBox or iText to extract text from PDF URL
        // Simplified here
        return ""; // TODO: implement PDF text extraction
    }

    private List<String> parseSkillNames(String json) {
        try {
            return new ObjectMapper().readValue(json, new TypeReference<List<String>>(){});
        } catch (Exception e) {
            return List.of();
        }
    }
}